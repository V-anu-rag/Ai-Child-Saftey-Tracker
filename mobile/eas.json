{
  "cli": {
    "version": ">= 18.8.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "EAS_BUILD_NPM_COMMAND": "npm install --legacy-peer-deps"
      }
    },
    "preview": {
      "channel": "preview",
      "distribution": "internal",
      "android": {
        "image": "ubuntu-22.04-jdk-17-ndk-r26b"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://safetrack-api.onrender.com/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://safetrack-api.onrender.com",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "EAS_BUILD_NPM_COMMAND": "npm install --legacy-peer-deps"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "image": "ubuntu-22.04-jdk-17-ndk-r26b"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://safetrack-api.onrender.com/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://safetrack-api.onrender.com",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "EAS_BUILD_NPM_COMMAND": "npm install --legacy-peer-deps"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
