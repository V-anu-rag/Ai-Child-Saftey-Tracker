{
  "cli": {
    "version": ">= 18.8.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "API_URL": "https://safetrack-api-preview.onrender.com/api",
        "SOCKET_URL": "https://safetrack-api-preview.onrender.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "API_URL": "https://safetrack-api.onrender.com/api",
        "SOCKET_URL": "https://safetrack-api.onrender.com",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "EAS_BUILD_NPM_COMMAND": "npm install --legacy-peer-deps"
      }
    }
  },
  "submit": {
    "production": {}
  }
}