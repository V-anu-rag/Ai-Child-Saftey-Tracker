{
  "expo": {
    "name": "SafeTrack",
    "slug": "safetrack",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "scheme": "safetrack",

    "orientation": "portrait",
    "userInterfaceStyle": "light",

    "icon": "./assets/logo.png",

    "owner": "verma_51",

    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.safetrack.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SafeTrack needs your location to keep your parent informed.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "SafeTrack tracks your location in background.",
        "NSLocationAlwaysUsageDescription": "SafeTrack uses background location."
      }
    },

    "android": {
      "package": "com.safetrack.app",
      "versionCode": 1,
      "usesCleartextTraffic": true,

      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#0A0F1E"
      },

      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },

    "plugins": [
      "expo-task-manager",

      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow SafeTrack to use your location to keep your parent informed.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,

          "foregroundService": {
            "notificationTitle": "SafeTrack Active",
            "notificationBody": "Location tracking is running to keep you safe.",
            "notificationColor": "#635BFF"
          }
        }
      ],

      "expo-notifications",

      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.2.0"
          }
        }
      ],

      "expo-secure-store",
      "expo-font",
      "expo-video"
    ],

    "extra": {
      "apiUrl": "https://safetrack-api.onrender.com/api",
      "socketUrl": "https://safetrack-api.onrender.com",

      "eas": {
        "projectId": "124c8979-964f-4391-908d-8a16cf67fc8e"
      }
    }
  }
}