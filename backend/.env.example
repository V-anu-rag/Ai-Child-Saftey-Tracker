# --- Server Configuration ---
PORT=5000
NODE_ENV=production

# --- Database ---
# Use MongoDB Atlas for production
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/safetrack?retryWrites=true&w=majority

# --- Security ---
# Secret for signing JWT tokens
JWT_SECRET=your_super_secret_jwt_random_string_here

# --- Client ---
# The URL of your deployed Next.js dashboard
CLIENT_URL=https://safetrack-dashboard.vercel.app

# --- Notifications (Firebase) ---
# Paste your Firebase service account JSON content or specific keys
FIREBASE_PROJECT_ID=safetrack-child-safety
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@...
